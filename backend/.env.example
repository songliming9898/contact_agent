# ContractAgent 环境变量配置 (MySQL版)
# 复制此文件为 .env 并填写真实值

# ==================== MySQL 配置 ====================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root123
MYSQL_DATABASE=contract_agent

# ==================== LLM 配置 ====================
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxx
LLM_MODEL=qwen-plus

# ==================== Embedding 配置 ====================
# EMBEDDING_MODEL=text-embedding-v2

# ==================== 后台管理 ====================
ADMIN_PASSWORD=admin123
JWT_SECRET_KEY=contract-agent-secret-key-2026

# ==================== 服务配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*
